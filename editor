// defaults to { name: null, age: null } — i.e. not personalised).
const CARD_OVERRIDES = {
    "thankyou-teacher": {
        name: { ...DEFAULT_NAME_SETTINGS, left: 900, top: 725, startSize: 52, minSize: 35, maxSize: 68, color: "#FD7D96" }
    }
};

// Build the final template lookup once, from the compact data above.
const CARD_TEMPLATES = Object.fromEntries(
    Object.entries(CARD_PATHS).map(([key, path]) => [
        key,
        { url: CLOUD_BASE + path, name: null, age: null, ...(CARD_OVERRIDES[key] || {}) }
    ])
);

// ---- Canvas / layout constants ----
const PANEL_WIDTH = 595.5, CANVAS_WIDTH = 1191, CANVAS_HEIGHT = 840;
const BOX_WIDTH = 495, BOX_HEIGHT = 225, BOX_LEFT = 50 + PANEL_WIDTH;
const BOX_TOPS = [40, 305, 570]; // top / middle / bottom inside panels
const BOX_DEFAULT_TEXTS = ["Add Message Here", "Happy Birthday!\nHave a great day!", "Add Message Here"];

const STYLE_DASHED = { borderDashArray: [4, 4], borderColor: "#cccccc", strokeWidth: 1.5 };
const STYLE_SOLID = { borderDashArray: null, borderColor: "#1A73E8", strokeWidth: 2 };

// ---- Mutable editor state ----
let canvas, bgImg, backCoverImg, nameText, ageText;
let leftPageBg, rightPageBg;
let insideBgRects = [];   // [top, middle, bottom]
let insideTexts = [];     // [top, middle, bottom]
let currentPage = "front", activeTemplate = null;

const $ = (id) => document.getElementById(id);

window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const cardId = params.get('card') || '11plus-boy';
    if (CARD_TEMPLATES[cardId]) {
        initEditor(cardId);
    } else {
        window.location.href = 'shop-cards.html';
    }
});

function initEditor(templateKey) {
    activeTemplate = CARD_TEMPLATES[templateKey];

    $("front-size-controls").style.display = activeTemplate.name?.canChangeSize ? "block" : "none";
    $("front-color").parentElement.style.display = activeTemplate.name?.canChangeColor ? "flex" : "none";

    const canvasElement = $("canvas");
    canvasElement.width = CANVAS_WIDTH;
    canvasElement.height = CANVAS_HEIGHT;

    canvas = new fabric.Canvas(canvasElement, {
        width: CANVAS_WIDTH, height: CANVAS_HEIGHT,
        preserveObjectStacking: true, backgroundColor: '#ffffff'
    });

    // Scale the on-screen canvas to 90% of its native size (visual only).
    // Internal working resolution stays at CANVAS_WIDTH x CANVAS_HEIGHT so
    // object coordinates, exports (toDataURL) and image quality are unaffected.
    canvas.setDimensions({
        width: CANVAS_WIDTH * 0.9,
        height: CANVAS_HEIGHT * 0.9
    }, { cssOnly: true });

    // Logo on the back cover panel
    fabric.Image.fromURL(`${CLOUD_BASE}v1784098145/logo.png`, (logoImg) => {
        backCoverImg = logoImg;
        backCoverImg.set({
            left: PANEL_WIDTH / 2, top: 710,
            originX: 'center', originY: 'center',
            scaleX: 0.15, scaleY: 0.15,
            selectable: false, evented: false
        });
        canvas.add(backCoverImg);
        canvas.sendToBack(backCoverImg);
    });

    // Show/hide the personalisation inputs based on what this card supports
    const hasPersonalisation = activeTemplate.name || activeTemplate.age;
    $('front-text-inputs').style.display = hasPersonalisation ? 'block' : 'none';
    if (hasPersonalisation) {
        $('name-input').style.display = $('label-name').style.display = activeTemplate.name ? 'block' : 'none';
        $('age-input').style.display = $('label-age').style.display = activeTemplate.age ? 'block' : 'none';
    }

    loadFrontCover(activeTemplate.url);
}

function loadFrontCover(imageUrl) {
    fabric.Image.fromURL(imageUrl, (img) => {
        bgImg = img;
        bgImg.set({
            left: PANEL_WIDTH, top: 0,
            scaleX: PANEL_WIDTH / bgImg.width,
            scaleY: CANVAS_HEIGHT / bgImg.height,
            selectable: false, evented: false
        });
        canvas.add(bgImg);
        canvas.sendToBack(bgImg);

        setupTextsAndOverlays();
        switchPage('front');
    });
}

function setupTextsAndOverlays() {
    if (activeTemplate.name) {
        const n = activeTemplate.name;
        nameText = new fabric.Text("NAME", {
            left: n.left, top: n.top, originX: "center", originY: "center",
            fontSize: n.startSize, fontFamily: n.fontFamily || "Arial",
            fontWeight: n.fontWeight || "bold", fill: n.color, textAlign: "center",
            hasControls: false, hasBorders: false, lockMovementX: true, lockMovementY: true
        });

        if (n.canChangeSize) {
            const slider = $("front-size");
            slider.min = n.minSize;
            slider.max = n.maxSize;
            slider.value = n.startSize;
            $("front-size-val").innerText = n.startSize + "px";
        }
        canvas.add(nameText);
    }

    if (activeTemplate.age) {
        const a = activeTemplate.age;
        ageText = new fabric.Text("40", {
            left: a.left, top: a.top, originX: "center", originY: "center",
            fontSize: a.startSize, fontFamily: a.fontFamily || "Arial", fontWeight: "bold",
            fill: a.color, hasControls: false, hasBorders: false, lockMovementX: true, lockMovementY: true
        });
        canvas.add(ageText);
    }

    leftPageBg = new fabric.Rect({ left: 0, top: 0, width: PANEL_WIDTH, height: CANVAS_HEIGHT, fill: '#ffffff', visible: false, selectable: false, evented: false });
    rightPageBg = new fabric.Rect({ left: PANEL_WIDTH, top: 0, width: PANEL_WIDTH, height: CANVAS_HEIGHT, fill: '#ffffff', visible: false, selectable: false, evented: false });

    const bgPanelDefaults = { width: BOX_WIDTH, height: BOX_HEIGHT, left: BOX_LEFT, fill: "#fcfcfc", rx: 8, ry: 8, selectable: false, evented: false, visible: false };
    insideBgRects = BOX_TOPS.map((top) => new fabric.Rect({ ...bgPanelDefaults, top }));

    const textDefaults = {
        width: BOX_WIDTH, height: BOX_HEIGHT, left: BOX_LEFT,
        fontFamily: "Arial", fill: "#000000", textAlign: "center",
        visible: false, hasControls: false,
        lockMovementX: true, lockMovementY: true, lockScalingX: true, lockScalingY: true,
        hasBorders: true, splitByGrapheme: true, backgroundColor: "transparent",
        ...STYLE_DASHED
    };
    insideTexts = BOX_TOPS.map((top, i) => new fabric.Textbox(BOX_DEFAULT_TEXTS[i], { ...textDefaults, top, fontSize: 45 }));

    canvas.add(leftPageBg, rightPageBg, ...insideBgRects, ...insideTexts);
    setupTextEvents();
}

function updateNameText(val) {
    if (!nameText) return;
    nameText.set({ text: val.toUpperCase() || "NAME" });
    if (activeTemplate.name.isCurved) updateTextCurve(nameText, activeTemplate.name.curveRadius);
    canvas.requestRenderAll();
}

function updateAgeText(val) {
    if (!ageText) return;
    ageText.set({ text: val || "40" });
    canvas.requestRenderAll();
}

function updateFrontColor(hexColor) {
    nameText?.set({ fill: hexColor });
    ageText?.set({ fill: hexColor });
    canvas.requestRenderAll();
}

function updateFrontSize(size) {
    $("front-size-val").innerText = size + "px";
    if (nameText) {
        nameText.set({ fontSize: Number(size) });
        if (activeTemplate.name?.isCurved) updateTextCurve(nameText, activeTemplate.name.curveRadius);
    }
    canvas.requestRenderAll();
}

function activeInsideText() {
    const active = canvas.getActiveObject();
    return insideTexts.includes(active) ? active : null;
}

function updateInsideSize(px) {
    $('size-val').innerText = px + "px";
    const active = activeInsideText();
    if (active) {
        active.set({ fontSize: Number(px) });
        canvas.requestRenderAll();
    }
}

function updateInsideColor(hexColor) {
    const active = activeInsideText();
    if (active) {
        active.set({ fill: hexColor });
        canvas.requestRenderAll();
    }
}

function switchPage(page) {
    currentPage = page;
    const isFront = page === 'front';

    $('toggle-front').classList.toggle('active', isFront);
    $('toggle-inside').classList.toggle('active', !isFront);
    $('front-controls').classList.toggle('active', isFront);
    $('inside-controls').classList.toggle('active', !isFront);

    [backCoverImg, bgImg, nameText, ageText].forEach((o) => o?.set({ visible: isFront }));
    [leftPageBg, rightPageBg, ...insideBgRects, ...insideTexts].forEach((o) => o.set({ visible: !isFront }));

    canvas.discardActiveObject();
    resetBordersToDashed();

    if (!isFront) insideTexts.forEach((t) => t.setCoords());
    canvas.requestRenderAll();
}

function setupTextEvents() {
    canvas.on("mouse:down", ({ target }) => {
        if (currentPage !== 'inside' || !insideTexts.includes(target)) return;
        resetBordersToDashed();
        target.set(STYLE_SOLID);
        $('inside-size').value = target.fontSize;
        $('size-val').innerText = target.fontSize + "px";
        $('inside-color').value = target.fill;
        canvas.requestRenderAll();
    });

    canvas.on('text:editing:entered', ({ target }) => {
        if (target.text === "Add Message Here") {
            target.text = "";
            target.hiddenTextarea.value = "";
            canvas.requestRenderAll();
        }
    });
}

function resetBordersToDashed() {
    insideTexts.forEach((t) => t.set(STYLE_DASHED));
}

function updateTextCurve(textObj, curveVal) {
    if (!textObj || curveVal <= 0) return;
    const widthSpan = 320, halfSpan = widthSpan / 2;
    const peakY = -Number(curveVal * 1.8);
    textObj.set({
        path: new fabric.Path(`M 0 0 Q ${halfSpan} ${peakY} ${widthSpan} 0`, { fill: '', stroke: '', visible: false }),
        left: activeTemplate.name.left, top: activeTemplate.name.top, originX: "center", originY: "center"
    });
}

async function uploadAndGoToCheckout() {
    const buyBtn = document.querySelector(".controls .btn");
    buyBtn.innerText = "Generating high-res pages...";
    buyBtn.disabled = true;

    try {
        switchPage('front');
        const page1DataUrl = canvas.toDataURL({ format: 'png', quality: 1.0 });

        switchPage('inside');
        resetBordersToDashed();
        insideBgRects.forEach((r) => r.set({ visible: false }));
        insideTexts.forEach((t) => t.set({ borderDashArray: null, borderColor: "transparent" }));
        canvas.discardActiveObject();
        canvas.requestRenderAll();

        const page2DataUrl = canvas.toDataURL({ format: 'png', quality: 1.0 });

        insideBgRects.forEach((r) => r.set({ visible: true }));
        switchPage('inside');

        buyBtn.innerText = "Uploading templates...";

        // Upload both pages in parallel for faster checkout
        const [p1Upload, p2Upload] = await Promise.all([
            uploadToCloudinary(page1DataUrl),
            uploadToCloudinary(page2DataUrl)
        ]);

        if (!p1Upload?.secure_url || !p2Upload?.secure_url) {
            throw new Error("Upload failed. Verify Cloudinary credentials.");
        }

        buyBtn.innerText = "Connecting checkout...";

        const checkoutData = {
            name: nameText?.text ?? "N/A",
            age: ageText?.text ?? "N/A",
            outsideImageUrl: p1Upload.secure_url,
            insideImageUrl: p2Upload.secure_url
        };

        const response = await fetch('/.netlify/functions/create-checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(checkoutData)
        });

        const session = await response.json();
        if (session.url) {
            window.location.href = session.url;
        } else {
            alert("Checkout Error: " + (session.error || "Please verify environment settings."));
            buyBtn.innerText = "Buy Now";
            buyBtn.disabled = false;
        }
    } catch (err) {
        console.error(err);
        alert("Processing failed. Check Cloudinary settings!");
        buyBtn.innerText = "Buy Now";
        buyBtn.disabled = false;
    }
}

async function uploadToCloudinary(base64Data) {
    const formData = new FormData();
    formData.append("file", base64Data);
    formData.append("upload_preset", CLOUDINARY_UPLOAD_PRESET);

    const res = await fetch(`https://api.cloudinary.com/v1_1/${CLOUDINARY_CLOUD_NAME}/image/upload`, {
        method: "POST",
        body: formData
    });
    return res.json();
}

function updateLoginUI(user) {
    const loginBtn = $("login-button");
    loginBtn.innerHTML = user ? "👤 Log Out" : "👤 Log In";
    loginBtn.setAttribute("onclick", user ? "netlifyIdentity.logout()" : "netlifyIdentity.open()");
}

function handleMyOrdersClick(event) {
    event.preventDefault();
    if (netlifyIdentity.currentUser()) {
        window.location.href = "orders.html";
    } else {
        alert("Please log in to view your order history.");
        netlifyIdentity.open('login');
    }
}
</script>
